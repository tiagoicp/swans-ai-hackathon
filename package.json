{
  "name": "swans-ai",
  "version": "1.0.0",
  "private": true,
  "description": "AI chat agent on Cloudflare — Swans AI Applied Hackathon, Lisbon 2026",
  "keywords": [
    "agents",
    "ai",
    "cloudflare"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "start": "vite dev",
    "deploy": "vite build && wrangler deploy",
    "types": "wrangler types",
    "types:check": "wrangler types --check",
    "format": "prettier --write .",
    "lint": "eslint .",
    "check": "npm run types:check && prettier --check . && eslint . && tsc",
    "prepare": "husky"
  },
  "dependencies": {
    "@cloudflare/ai-chat": "^0.10.0",
    "@cloudflare/kumo": "^2.6.0",
    "@phosphor-icons/react": "^2.1.10",
    "@streamdown/code": "^1.1.1",
    "agents": "^0.19.0",
    "ai": "^7.0.36",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "streamdown": "^2.5.0",
    "workers-ai-provider": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^8.0.2",
    "@cloudflare/vite-plugin": "1.47.0",
    "@eslint/js": "^9.39.5",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "prettier": "^3.9.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.0",
    "wrangler": "^4.114.0"
  },
  "allowScripts": {
    "core-js-pure@3.49.0": true,
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "fsevents@2.3.3": true,
    "workerd": false
  }
}
